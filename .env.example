# ============================================================
# MARC 系统 LLM 配置模板
#
# 使用方法：
#   cp .env.example .env
#   编辑 .env，按需选择下方任一配置方案，填入你的 API key
#   .env 已在 .gitignore 中，不会被提交到版本库
# ============================================================

# ── 方案 A：Anthropic（默认） ──────────────────────────────────
# 不设置 LLM_BASE_URL 时，系统自动使用 Anthropic 原生接口
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-6

# ── 方案 B：OpenAI 兼容接口 ────────────────────────────────────
# 设置 LLM_BASE_URL 后，系统切换为 OpenAI 兼容接口
# 需要额外安装：pip install openai
#
# 使用 OpenAI GPT：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
#
# 使用智谱 GLM（ChatGLM）：
# LLM_API_KEY=your-zhipu-api-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4-plus
#
# 使用 MiniMax：
# LLM_API_KEY=your-minimax-api-key
# LLM_BASE_URL=https://api.minimax.chat/v1
# LLM_MODEL=abab6.5s-chat
#
# 使用 DeepSeek：
# LLM_API_KEY=your-deepseek-api-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# 使用本地 Ollama（无需 API key）：
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# ── Embedding 配置 ─────────────────────────────────────────────
# Dense 向量检索使用的 SentenceTransformers 模型（本地运行，无需 API）
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 更高精度选项（需要更多内存）：
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
